# ===== REQUIRED =====

# PostgreSQL database URL
# Free options: Neon.tech, Supabase, Railway, ElephantSQL
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/okeno

# Domain where the API server runs (used by the Expo client)
# For local dev: localhost:5000
# For production: your-domain.com
EXPO_PUBLIC_DOMAIN=localhost:5000

# Full server URL (used by server CORS & Stripe redirects)
# For local dev: http://localhost:5000
# For production: https://your-domain.com
SERVER_URL=http://localhost:5000

# Port for the Express server
PORT=5000

# ===== STRIPE (optional - for premium features) =====

# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook secret (for production webhook verification)
# Get from: stripe listen --forward-to localhost:5000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ===== OPTIONAL =====

# OpenAI API Key (for content moderation)
OPENAI_API_KEY=sk-...

# Additional allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=
